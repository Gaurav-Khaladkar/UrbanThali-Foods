NODE_ENV=development
API_PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/urbanthali
REDIS_URL=redis://localhost:6379
AWS_REGION=ap-south-1
AWS_S3_BUCKET=urbanthali-assets
AWS_CLOUDFRONT_DOMAIN=cdn.urbanthali.local
QUEUE_PROVIDER=bullmq
BULLMQ_QUEUE_NAME=daily-manifest-jobs
SQS_QUEUE_NAME=urbanthali-sqs-jobs
FCM_PROJECT_ID=urbanthali-notify
FCM_SERVER_KEY=your_fcm_server_key
RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
STRIPE_PUBLISHABLE_KEY=your_stripe_key
GOOGLE_MAPS_API_KEY=your_maps_key
